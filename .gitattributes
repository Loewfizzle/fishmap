# .gitattributes (Issue 12 fix)
# Enforce consistent line endings for cross-platform (Windows Git default core.autocrlf=true).
# Prevents noisy diffs, shebang breakage, and tool warnings on text files.
# * text=auto is safe default; explicit LF for code/shell/configs that matter.

* text=auto

# Code and scripts: always LF (Unix convention, Python/JSON/TS tolerate but prefer LF)
*.py text eol=lf
*.sh text eol=lf
Makefile text eol=lf
Dockerfile* text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.css text eol=lf
*.html text eol=lf
*.txt text eol=lf

# Configs and data that should be LF
.gitattributes text eol=lf
.gitignore text eol=lf
pyproject.toml text eol=lf
tsconfig*.json text eol=lf
postcss.config.js text eol=lf
tailwind.config.js text eol=lf
vite.config.ts text eol=lf

# Binary or generated (no EOL normalization)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.tar.gz binary
*.pmtiles binary
*.mbtiles binary
*.tsbuildinfo binary
*.exe binary
